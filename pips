<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Plumb3D - Jasa Perbaikan Pipa Tersumbat Modern</title>
    <!-- Tailwind CSS untuk Desain Cepat & Clean -->
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <!-- Three.js untuk Render 3D -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
    <style>
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: #0f172a;
            color: #f8fafc;
            overflow-x: hidden;
        }
        #canvas-3d {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: 1;
            pointer-events: none; /* Supaya tombol di atasnya bisa diklik */
        }
        .content-overlay {
            position: relative;
            z-index: 10;
        }
        .glassmorphism {
            background: rgba(30, 41, 59, 0.7);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.1);
        }
    </style>
</head>
<body>

    <!-- Latar Belakang Elemen 3D -->
    <div id="canvas-3d"></div>

    <!-- Konten Utama (Overlay) -->
    <div class="content-overlay min-h-screen flex flex-col justify-between">
        
        <!-- Navbar -->
        <header class="p-6">
            <nav class="max-w-7xl mx-auto flex justify-between items-center glassmorphism p-4 rounded-2xl shadow-lg">
                <div class="text-2xl font-bold tracking-wider text-blue-400 flex items-center gap-2">
                    💧 Plumb<span class="text-white">3D</span>
                </div>
                <ul class="hidden md:flex gap-8 font-medium">
                    <li><a href="#solusi" class="hover:text-blue-400 transition">Solusi</a></li>
                    <li><a href="#keunggulan" class="hover:text-blue-400 transition">Keunggulan</a></li>
                    <li><a href="#kontak" class="hover:text-blue-400 transition">Hubungi Kami</a></li>
                </ul>
                <a href="https://wa.me/628123456789" target="_blank" class="bg-blue-500 hover:bg-blue-600 text-white font-semibold px-5 py-2 rounded-xl transition shadow-lg shadow-blue-500/30">
                    Respon Cepat
                </a>
            </nav>
        </header>

        <!-- Hero Section -->
        <main class="max-w-7xl mx-auto px-6 py-12 flex-grid grid-cols-1 lg:grid-cols-2 items-center gap-12 my-auto">
            <div class="max-w-2xl space-y-6">
                <div class="inline-block bg-blue-500/20 text-blue-400 font-semibold px-4 py-1.5 rounded-full text-sm uppercase tracking-wider border border-blue-500/30">
                    🛠️ Layanan 24/7 Anti Ribet
                </div>
                <h1 class="text-4xl md:text-6xl font-extrabold leading-tight">
                    Pipa Tersumbat? <br>
                    <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-cyan-400">Kami Lancarkan</span> <br>
                    Tanpa Bongkar!
                </h1>
                <p class="text-slate-400 text-lg md:text-xl">
                    Menggunakan teknologi deteksi sonar dan pembersihan hidrolik modern. Cepat, bersih, dan bergaransi resmi.
                </p>
                <div class="flex flex-wrap gap-4 pt-4">
                    <a href="https://wa.me/628123456789" class="bg-gradient-to-r from-blue-500 to-cyan-500 hover:from-blue-600 hover:to-cyan-600 text-white font-bold px-8 py-4 rounded-xl shadow-xl shadow-blue-500/20 transition transform hover:-translate-y-1 text-center w-full sm:w-auto">
                        Panggil Teknisi Sekarang
                    </a>
                    <a href="#solusi" class="glassmorphism hover:bg-slate-800 text-white font-medium px-8 py-4 rounded-xl transition text-center w-full sm:w-auto">
                        Lihat Layanan
                    </a>
                </div>
            </div>

            <!-- Kartu Info Singkat -->
            <div class="grid grid-cols-2 gap-4 mt-12 lg:mt-0">
                <div class="glassmorphism p-6 rounded-2xl">
                    <h3 class="text-3xl font-bold text-blue-400 mb-1">30 mnt</h3>
                    <p class="text-sm text-slate-400">Estimasi Tiba di Lokasi</p>
                </div>
                <div class="glassmorphism p-6 rounded-2xl">
                    <h3 class="text-3xl font-bold text-cyan-400 mb-1">100%</h3>
                    <p class="text-sm text-slate-400">Garansi Uang Kembali</p>
                </div>
            </div>
        </main>

        <!-- Footer -->
        <footer class="p-6 text-center text-sm text-slate-500 border-t border-slate-800/60 glassmorphism mt-12">
            © 2026 Plumb3D Indonesia. Semua Hak Dilindungi.
        </footer>
    </div>

    <!-- Script Three.js untuk Efek Pipa & Air 3D -->
    <script>
        // 1. Setup Scene, Kamera, dan Renderer
        const scene = new THREE.Scene();
        const camera = new THREE.PerspectiveCamera(75, window.innerWidth / window.innerHeight, 01, 1000);
        const renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true });
        
        renderer.setSize(window.innerWidth, window.innerHeight);
        document.getElementById('canvas-3d').appendChild(renderer.domElement);

        // 2. Membuat Objek 3D (Simulasi Pipa Melengkung)
        class CustomSineCurve extends THREE.Curve {
            constructor(scale = 1) {
                super();
                this.scale = scale;
            }
            getPoint(t, optionalTarget = new THREE.Vector3()) {
                const tx = t * 6 - 3;
                const ty = Math.sin(t * Math.PI * 2) * 1.5;
                const tz = Math.cos(t * Math.PI * 1.5) * 1;
                return optionalTarget.set(tx, ty, tz).multiplyScalar(this.scale);
            }
        }

        const path = new CustomSineCurve(2);
        const pipeGeometry = new THREE.TubeGeometry(path, 100, 0.4, 20, false);
        
        // Material Pipa (Efek Glossy Transparan)
        const pipeMaterial = new THREE.MeshPhysicalMaterial({
            color: 0x3b82f6,
            roughness: 0.1,
            metalness: 0.1,
            transparent: true,
            opacity: 0.4,
            transmission: 0.6, // Efek kaca/plastik tebal
            ior: 1.5
        });
        const pipeMesh = new THREE.Mesh(pipeGeometry, pipeMaterial);
        scene.add(pipeMesh);

        // Tambahkan partikel di dalam pipa (Mensimulasikan air/kotoran mengalir)
        const particleCount = 200;
        const particleGeometry = new THREE.BufferGeometry();
        const positions = new Float32Array(particleCount * 3);

        for(let i=0; i<particleCount; i++) {
            const t = Math.random();
            const point = path.getPoint(t);
            positions[i*3] = point.x;
            positions[i*3+1] = point.y + (Math.random() - 0.5) * 0.2;
            positions[i*3+2] = point.z + (Math.random() - 0.5) * 0.2;
        }

        particleGeometry.setAttribute('position', new THREE.BufferAttribute(positions, 3));
        const particleMaterial = new THREE.PointsMaterial({
            color: 0x22d3ee,
            size: 0.08,
            transparent: true,
            opacity: 0.8
        });
        const waterParticles = new THREE.Points(particleGeometry, particleMaterial);
        scene.add(waterParticles);

        // 3. Pencahayaan (Lighting)
        const ambientLight = new THREE.AmbientLight(0xffffff, 0.6);
        scene.add(ambientLight);

        const directionalLight = new THREE.DirectionalLight(0x22d3ee, 2);
        directionalLight.position.set(5, 10, 7);
        scene.add(directionalLight);

        const pointLight = new THREE.PointLight(0x3b82f6, 1, 100);
        pointLight.position.set(-5, -5, 5);
        scene.add(pointLight);

        // Posisikan Kamera
        camera.position.z = 10;
        camera.position.x = 2;

        // 4. Animasi Loop
        function animate() {
            requestAnimationFrame(animate);

            // Rotasi perlahan untuk efek dinamis
            pipeMesh.rotation.y += 0.002;
            pipeMesh.rotation.x = Math.sin(Date.now() * 0.0005) * 0.2;
            
            waterParticles.rotation.y += 0.002;
            waterParticles.rotation.x = Math.sin(Date.now() * 0.0005) * 0.2;

            // Animasi partikel air bergerak di dalam pipa
            const positions = waterParticles.geometry.attributes.position.array;
            for(let i = 0; i < particleCount; i++) {
                positions[i*3] += 0.02; // Gerakan maju x
                if (positions[i*3] > 6) { // Jika keluar batas, reset ke awal pipa
                    positions[i*3] = -6;
                }
            }
            waterParticles.geometry.attributes.position.needsUpdate = true;

            renderer.render(scene, camera);
        }
        animate();

        // 5. Responsive Design (Sesuai Ukuran Layar)
        window.addEventListener('resize', onWindowResize, false);
        function onWindowResize() {
            camera.aspect = window.innerWidth / window.innerHeight;
            camera.updateProjectionMatrix();
            renderer.setSize(window.innerWidth, window.innerHeight);
            
            // Penyesuaian posisi kamera untuk layar hp
            if(window.innerWidth < 768) {
                camera.position.z = 14;
                camera.position.x = 0;
            } else {
                camera.position.z = 10;
                camera.position.x = 2;
            }
        }
        // Jalankan fungsi sekali saat start untuk cek ukuran layar
        onWindowResize();
    </script>
</body>
</html>
